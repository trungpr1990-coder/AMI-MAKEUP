---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Đặt Lịch — AMI Makeup Academy" description="Đặt lịch học hoặc dịch vụ makeup tại AMI Makeup Academy. Liên hệ qua Zalo, Facebook hoặc gọi điện trực tiếp.">

  <div class="bg-ink py-20 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <span class="section-label justify-center flex">Nhanh & Tiện Lợi</span>
      <h1 class="font-serif text-5xl font-semibold text-white">Đặt Lịch</h1>
      <p class="text-zinc-400 mt-4">Liên hệ với AMI qua kênh thuận tiện nhất cho bạn.</p>
    </div>
  </div>

  <section class="py-20 bg-cream">
    <div class="max-w-3xl mx-auto px-6">
      <div class="grid gap-5">
        <a href="https://zalo.me/0123456789" target="_blank" class="flex items-center gap-5 bg-white border border-zinc-100 p-6 hover:border-gold/50 card-hover group">
          <div class="w-14 h-14 bg-[#0068FF] rounded-full flex items-center justify-center shrink-0">
            <span class="text-white font-bold text-lg">Z</span>
          </div>
          <div class="flex-1">
            <div class="font-semibold text-ink text-lg group-hover:text-gold transition-colors">Nhắn Zalo</div>
            <div class="text-zinc-400 text-sm mt-1">Phản hồi nhanh nhất — trong vòng 30 phút</div>
          </div>
          <svg class="w-5 h-5 text-zinc-300 group-hover:text-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>

        <a href="tel:0912345678" class="flex items-center gap-5 bg-white border border-zinc-100 p-6 hover:border-gold/50 card-hover group">
          <div class="w-14 h-14 bg-gold rounded-full flex items-center justify-center shrink-0 text-2xl">📞</div>
          <div class="flex-1">
            <div class="font-semibold text-ink text-lg group-hover:text-gold transition-colors">Gọi Điện Trực Tiếp</div>
            <div class="text-zinc-400 text-sm mt-1">0912 345 678 — Thứ 2 đến CN, 8:00–20:00</div>
          </div>
          <svg class="w-5 h-5 text-zinc-300 group-hover:text-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>

        <a href="https://facebook.com/amimakeupacademy" target="_blank" class="flex items-center gap-5 bg-white border border-zinc-100 p-6 hover:border-gold/50 card-hover group">
          <div class="w-14 h-14 bg-[#1877F2] rounded-full flex items-center justify-center shrink-0">
            <span class="text-white font-bold text-xl">f</span>
          </div>
          <div class="flex-1">
            <div class="font-semibold text-ink text-lg group-hover:text-gold transition-colors">Nhắn Facebook</div>
            <div class="text-zinc-400 text-sm mt-1">AMI Makeup Academy — fanpage chính thức</div>
          </div>
          <svg class="w-5 h-5 text-zinc-300 group-hover:text-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>

        <a href="mailto:ami.makeup.academy@gmail.com" class="flex items-center gap-5 bg-white border border-zinc-100 p-6 hover:border-gold/50 card-hover group">
          <div class="w-14 h-14 bg-zinc-700 rounded-full flex items-center justify-center shrink-0 text-2xl">✉</div>
          <div class="flex-1">
            <div class="font-semibold text-ink text-lg group-hover:text-gold transition-colors">Gửi Email</div>
            <div class="text-zinc-400 text-sm mt-1">ami.makeup.academy@gmail.com</div>
          </div>
          <svg class="w-5 h-5 text-zinc-300 group-hover:text-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="mt-10 bg-white border border-zinc-100 p-8 text-center">
        <div class="font-serif text-2xl font-semibold text-ink mb-3">Lưu Ý Khi Đặt Lịch</div>
        <p class="text-zinc-500 text-sm leading-relaxed">
          Khi liên hệ, vui lòng cho biết: <strong class="text-ink">Dịch vụ / khoá học</strong> bạn quan tâm, <strong class="text-ink">ngày & giờ</strong> mong muốn, và <strong class="text-ink">tên</strong> để AMI lên lịch cho bạn.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
