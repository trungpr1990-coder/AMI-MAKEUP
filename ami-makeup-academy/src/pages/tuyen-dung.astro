---
import BaseLayout from '../layouts/BaseLayout.astro';

const positions = [
  {
    title: 'Makeup Artist',
    type: 'Part-time / Full-time',
    location: 'TP. Nam Định',
    salary: 'Thỏa thuận',
    requirements: ['Đã có kinh nghiệm makeup (ưu tiên học viên AMI)', 'Tay nghề ổn định, thái độ chuyên nghiệp', 'Sáng tạo, cập nhật xu hướng', 'Có thể làm việc cuối tuần'],
  },
  {
    title: 'Trợ Giảng Makeup',
    type: 'Part-time',
    location: 'TP. Nam Định',
    salary: 'Thỏa thuận',
    requirements: ['Đã hoàn thành khoá học tại AMI', 'Kỹ năng giao tiếp tốt', 'Kiên nhẫn, tận tâm với học viên', 'Có kinh nghiệm dạy học (lợi thế)'],
  },
];
---

<BaseLayout title="Tuyển Dụng — AMI Makeup Academy" description="AMI Makeup Academy tuyển dụng Makeup Artist và Trợ Giảng tại Nam Định.">

  <!-- Header -->
  <div class="bg-ink py-20 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <span class="section-label justify-center flex">Gia Nhập Đội Ngũ</span>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold text-white">Tuyển Dụng</h1>
      <p class="text-zinc-400 mt-4">Cùng AMI xây dựng cộng đồng làm đẹp chuyên nghiệp tại Nam Định</p>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="bg-cream border-b border-zinc-200">
    <div class="max-w-7xl mx-auto px-6 py-3 text-xs text-zinc-400">
      <a href="/" class="hover:text-gold transition-colors">Trang Chủ</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-600">Tuyển Dụng</span>
    </div>
  </div>

  <!-- Positions -->
  <section class="py-20 bg-cream">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="section-label">Vị Trí Tuyển Dụng</span>
        <h2 class="section-title">Đang Mở</h2>
      </div>
      <div class="space-y-6">
        {positions.map(pos => (
          <div class="bg-white border border-zinc-100 p-8">
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-6">
              <div>
                <h3 class="font-serif text-2xl font-semibold text-ink mb-2">{pos.title}</h3>
                <div class="flex flex-wrap gap-4 text-sm text-zinc-500">
                  <span class="flex items-center gap-1">📅 {pos.type}</span>
                  <span class="flex items-center gap-1">📍 {pos.location}</span>
                  <span class="flex items-center gap-1">💰 {pos.salary}</span>
                </div>
              </div>
              <a href="/lien-he" class="btn-gold shrink-0">Ứng Tuyển</a>
            </div>
            <div>
              <h4 class="text-[10px] font-semibold tracking-widest uppercase text-zinc-400 mb-3">Yêu Cầu</h4>
              <ul class="space-y-2">
                {pos.requirements.map(r => (
                  <li class="flex items-center gap-3 text-sm text-zinc-600">
                    <span class="text-gold shrink-0">✓</span>
                    {r}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <!-- Benefits -->
      <div class="mt-12 bg-ink text-white p-10">
        <h3 class="font-serif text-2xl font-semibold mb-6">Quyền Lợi Khi Làm Tại AMI</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            'Môi trường làm việc chuyên nghiệp, thân thiện',
            'Được đào tạo và nâng cao kỹ năng liên tục',
            'Thu nhập cạnh tranh, thưởng theo hiệu quả',
            'Cộng đồng học viên & đồng nghiệp hỗ trợ',
            'Lịch làm việc linh hoạt',
            'Ưu đãi học khóa nâng cao tại AMI',
          ].map(b => (
            <div class="flex items-center gap-3 text-sm">
              <span class="text-gold shrink-0">✓</span>
              <span class="text-zinc-300">{b}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Apply CTA -->
      <div class="mt-8 bg-gold p-8 text-white text-center">
        <h3 class="font-serif text-2xl font-semibold mb-3">Nộp Hồ Sơ</h3>
        <p class="text-white/80 mb-5">Gửi CV và portfolio về email hoặc Zalo của AMI. Chúng tôi phản hồi trong vòng 48 giờ.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="mailto:ami.makeup.academy@gmail.com" class="bg-white text-gold font-semibold text-xs tracking-widest uppercase px-6 py-3 hover:bg-cream transition-colors">Gửi Email</a>
          <a href="https://zalo.me/0123456789" target="_blank" class="border border-white text-white font-semibold text-xs tracking-widest uppercase px-6 py-3 hover:bg-white hover:text-gold transition-colors">Nhắn Zalo</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
