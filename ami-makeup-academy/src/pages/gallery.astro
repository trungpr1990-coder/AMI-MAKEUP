---

<BaseLayout title="Gallery — AMI Makeup Academy" description="Portfolio tác phẩm của học viên và dịch vụ makeup tại AMI Makeup Academy.">

  <!-- Header -->
  <div class="bg-ink py-20 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <span class="section-label justify-center flex">Portfolio</span>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold text-white">Gallery</h1>
      <p class="text-zinc-400 mt-4">Tác phẩm của học viên & dịch vụ makeup tại AMI</p>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="bg-cream border-b border-zinc-200">
    <div class="max-w-7xl mx-auto px-6 py-3 text-xs text-zinc-400">
      <a href="/" class="hover:text-gold transition-colors">Trang Chủ</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-600">Gallery</span>
    </div>
  </div>

  <!-- Gallery Grid -->
  <section class="py-16 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="columns-2 md:columns-3 lg:columns-4 gap-3 space-y-3" id="gallery-grid">
        {images.map((img, i) => (
          <div
            class="break-inside-avoid overflow-hidden group cursor-zoom-in"
            data-index={i}
            onclick={`openLightbox(${i})`}
          >
            <img
              src={img.src}
              alt={img.alt}
              class="w-full object-cover group-hover:opacity-90 transition-opacity duration-300"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-black/95 z-50 hidden items-center justify-center" role="dialog" aria-modal="true" aria-label="Image lightbox">
    <button onclick="closeLightbox()" class="absolute top-5 right-6 text-white text-3xl hover:text-gold transition-colors z-10" aria-label="Đóng">✕</button>
    <button onclick="prevImage()" class="absolute left-4 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-gold transition-colors z-10 px-4 py-6" aria-label="Ảnh trước">‹</button>
    <button onclick="nextImage()" class="absolute right-4 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-gold transition-colors z-10 px-4 py-6" aria-label="Ảnh sau">›</button>
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain" />
    <div id="lightbox-caption" class="absolute bottom-5 left-1/2 -translate-x-1/2 text-zinc-400 text-sm tracking-wide"></div>
  </div>

  <!-- CTA -->
  <section class="py-16 bg-gold text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-3xl font-semibold text-white mb-4">Muốn Thành Thạo Như Thế Này?</h2>
      <p class="text-white/80 mb-8">Tham gia khoá học tại AMI và tạo nên những tác phẩm của riêng bạn.</p>
      <a href="/khoa-hoc" class="bg-white text-gold font-semibold text-sm tracking-widest uppercase px-8 py-4 hover:bg-cream transition-colors inline-block">Xem Khóa Học</a>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ galleryData: images.map(i => ({ src: i.src, alt: i.alt })) }}>
  const images = galleryData;
  let current = 0;

  function openLightbox(index) {
    current = index;
    document.getElementById('lightbox').style.display = 'flex';
    document.body.style.overflow = 'hidden';
    updateLightbox();
  }
  function closeLightbox() {
    document.getElementById('lightbox').style.display = 'none';
    document.body.style.overflow = '';
  }
  function updateLightbox() {
    document.getElementById('lightbox-img').src = images[current].src;
    document.getElementById('lightbox-img').alt = images[current].alt;
    document.getElementById('lightbox-caption').textContent = `${current + 1} / ${images.length} — ${images[current].alt}`;
  }
  function prevImage() { current = (current - 1 + images.length) % images.length; updateLightbox(); }
  function nextImage() { current = (current + 1) % images.length; updateLightbox(); }

  document.addEventListener('keydown', (e) => {
    if (document.getElementById('lightbox').style.display === 'flex') {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevImage();
      if (e.key === 'ArrowRight') nextImage();
    }
  });
</script>
