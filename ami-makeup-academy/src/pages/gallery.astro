  { src: '/images/IMG_2923.JPG', alt: 'Học viên AMI - Makeup đi tiệc' },
  { src: '/images/IMG_2924.JPG', alt: 'Học viên AMI - Makeup kỷ yếu' },
  { src: '/images/IMG_2925.JPG', alt: 'Học viên AMI - Makeup cá nhân' },
  { src: '/images/IMG_4846.jpeg', alt: 'Bridal makeup AMI' },
  { src: '/images/IMG_4850.jpeg', alt: 'Bridal makeup AMI' },
  { src: '/images/IMG_4851.jpeg', alt: 'Bridal makeup AMI' },
  { src: '/images/IMG_4853.jpeg', alt: 'Makeup chụp ảnh AMI' },
  { src: '/images/IMG_5284.jpeg', alt: 'Học viên thực hành' },
  { src: '/images/IMG_5287.jpeg', alt: 'Học viên thực hành' },
  { src: '/images/IMG_5288.jpeg', alt: 'Kết quả sau khoá học' },
  { src: '/images/IMG_5289.jpeg', alt: 'Kết quả sau khoá học' },
  { src: '/images/IMG_5290.jpeg', alt: 'Makeup cô dâu' },
  { src: '/images/IMG_8117.JPG', alt: 'Tốt nghiệp AMI 2025' },
  { src: '/images/IMG_8118.JPG', alt: 'Tốt nghiệp AMI 2025' },
  { src: '/images/IMG_8119.JPG', alt: 'Tốt nghiệp AMI 2025' },
  { src: '/images/IMG_8399.JPG', alt: 'Makeup cô dâu' },
  { src: '/images/IMG_8400.JPG', alt: 'Makeup cô dâu' },
  { src: '/images/IMG_8561.JPG', alt: 'Học viên thực hành' },
  { src: '/images/IMG_8562.JPG', alt: 'Học viên thực hành' },
  { src: '/images/IMG_9013.JPG', alt: 'Makeup sự kiện' },
  { src: '/images/IMG_9014.JPG', alt: 'Makeup sự kiện' },
  { src: '/images/IMG_9501.jpg', alt: 'Portfolio học viên' },
  { src: '/images/IMG_9502.jpg', alt: 'Portfolio học viên' },
  { src: '/images/SLI00416.jpeg', alt: 'Lớp học AMI' },
  { src: '/images/SLI00429.jpeg', alt: 'Lớp học AMI' },
  { src: '/images/SLI00432.jpeg', alt: 'Lớp học AMI' },
  { src: '/images/SLI00433.jpeg', alt: 'Lớp học AMI' },
  { src: '/images/SLI00437.jpeg', alt: 'Lớp học AMI' },
