---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { courses } from '../../data/courses';

export function getStaticPaths() {
  return courses.map(c => ({ params: { slug: c.slug }, props: { course: c } }));
}

const { course } = Astro.props;
const others = courses.filter(c => c.id !== course.id).slice(0, 3);
---

<BaseLayout title={`${course.ten} — AMI Makeup Academy`} description={course.mo_ta_ngan}>

  <!-- Hero -->
  <div class="bg-ink">
    <div class="max-w-7xl mx-auto px-6 pt-14 pb-0">
      <nav class="text-xs text-zinc-500 mb-8" aria-label="breadcrumb">
        <a href="/" class="hover:text-gold">Trang Chủ</a>
        <span class="mx-2">/</span>
        <a href="/khoa-hoc" class="hover:text-gold">Khóa Học</a>
        <span class="mx-2">/</span>
        <span class="text-zinc-300">{course.ten_ngan}</span>
      </nav>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-end">
        <div class="pb-16">
          <span class="text-gold text-[10px] font-semibold tracking-widest uppercase mb-3 block">{course.the}</span>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold text-white leading-tight mb-5">{course.ten}</h1>
          <p class="text-zinc-300 leading-relaxed text-lg mb-8">{course.mo_ta_ngan}</p>
          <div class="flex flex-wrap gap-4">
            <div class="bg-zinc-800 px-5 py-3">
              <div class="text-zinc-400 text-[9px] tracking-widest uppercase mb-1">Học Phí</div>
              <div class="text-gold font-bold text-2xl">{course.gia}</div>
              <div class="text-zinc-500 text-xs line-through">{course.gia_goc}</div>
            </div>
            <div class="bg-zinc-800 px-5 py-3">
              <div class="text-zinc-400 text-[9px] tracking-widest uppercase mb-1">Thời Lượng</div>
              <div class="text-white font-semibold">{course.thoi_luong}</div>
            </div>
            <div class="bg-zinc-800 px-5 py-3">
              <div class="text-zinc-400 text-[9px] tracking-widest uppercase mb-1">Lịch Học</div>
              <div class="text-white font-semibold">{course.buoi_hoc}</div>
            </div>
          </div>
        </div>
        <div class="hidden lg:block">
          <img src={course.hinh} alt={course.ten} class="w-full h-80 object-cover opacity-80" loading="eager" />
        </div>
      </div>
    </div>
  </div>

  <!-- Content -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Main content -->
        <div class="lg:col-span-2 space-y-10">
          <!-- Description -->
          <div>
            <h2 class="font-serif text-2xl font-semibold text-ink mb-5">Giới Thiệu Khoá Học</h2>
            <div class="text-zinc-600 leading-relaxed" set:html={course.mo_ta_day_du} />
          </div>

          <!-- Curriculum -->
          <div>
            <h2 class="font-serif text-2xl font-semibold text-ink mb-5">Nội Dung Khoá Học</h2>
            <div class="space-y-3">
              {course.noi_dung.map((item, i) => (
                <div class="flex gap-4 bg-white p-4 border border-zinc-100">
                  <span class="font-serif text-gold font-bold text-lg w-6 shrink-0">{String(i + 1).padStart(2, '0')}</span>
                  <span class="text-zinc-700 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Benefits -->
          <div>
            <h2 class="font-serif text-2xl font-semibold text-ink mb-5">Quyền Lợi Học Viên</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {course.duoc_hoc.map(item => (
                <div class="flex items-start gap-3 bg-white p-4 border border-zinc-100">
                  <span class="text-gold mt-0.5 shrink-0">✓</span>
                  <span class="text-zinc-700 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Quick info -->
          <div class="bg-white border border-zinc-200 p-6">
            <h3 class="font-serif text-lg font-semibold text-ink mb-5 pb-3 border-b border-zinc-100">Thông Tin Khoá Học</h3>
            <div class="space-y-4">
              {[
                ['Thời Lượng', course.thoi_luong, '⏱'],
                ['Lịch Học', course.buoi_hoc, '📅'],
                ['Sĩ Số', course.so_hoc_vien, '👥'],
                ['Địa Điểm', course.dia_diem, '📍'],
              ].map(([label, value, icon]) => (
                <div class="flex items-start gap-3">
                  <span class="text-gold shrink-0 mt-0.5">{icon}</span>
                  <div>
                    <div class="text-[10px] text-zinc-400 tracking-widest uppercase font-semibold mb-0.5">{label}</div>
                    <div class="text-sm text-zinc-700">{value}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- CTA card -->
          <div class="bg-gold p-6 text-white">
            <h3 class="font-serif text-xl font-semibold mb-3">Đăng Ký Tư Vấn</h3>
            <p class="text-white/80 text-sm mb-5 leading-relaxed">Liên hệ để được tư vấn chi tiết và đặt chỗ ngay hôm nay.</p>
            <a href="tel:0912345678" class="block bg-white text-gold font-semibold text-xs tracking-widest uppercase text-center py-3 mb-3 hover:bg-cream transition-colors">
              Gọi: 0912 345 678
            </a>
            <a href="https://zalo.me/0123456789" target="_blank" class="block border border-white/50 text-white font-semibold text-xs tracking-widest uppercase text-center py-3 hover:bg-white/10 transition-colors">
              Nhắn Zalo
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other courses -->
  {others.length > 0 && (
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-6">
        <h2 class="font-serif text-3xl font-semibold text-ink mb-10">Khóa Học Khác</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {others.map(c => (
            <a href={`/khoa-hoc/${c.slug}`} class="group border border-zinc-100 overflow-hidden card-hover">
              <div class="h-48 overflow-hidden bg-zinc-100">
                <img src={c.hinh} alt={c.ten} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <h3 class="font-serif text-base font-semibold text-ink group-hover:text-gold transition-colors mb-2">{c.ten}</h3>
                <div class="text-gold font-bold">{c.gia}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
