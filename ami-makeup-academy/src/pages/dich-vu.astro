---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    icon: '💍',
    title: 'Makeup Cô Dâu',
    desc: 'Trọn gói ngày cưới, đảm bảo đẹp từ sáng tới tối. Phong cách từ cô dâu ngây thơ tự nhiên đến sang trọng quyến rũ.',
    features: ['Thử makeup trước 1-2 tuần', 'Makeup theo phong cách yêu cầu', 'Có mặt đúng giờ tại địa điểm', 'Chỉnh sửa makeup trong ngày cưới'],
    price: 'Từ 800.000đ',
    img: '/images/IMG_4846.jpeg',
  },
  {
    icon: '🎓',
    title: 'Makeup Kỷ Yếu',
    desc: 'Lưu giữ khoảnh khắc đẹp nhất thời học sinh. Makeup tươi sáng, tự nhiên, phù hợp chụp ảnh ngoài trời và studio.',
    features: ['Makeup trẻ trung, tươi sáng', 'Phù hợp chụp ảnh ngoài trời', 'Bền màu suốt buổi chụp', 'Có thể làm tóc kết hợp'],
    price: 'Từ 350.000đ',
    img: '/images/IMG_5284.jpeg',
  },
  {
    icon: '✨',
    title: 'Makeup Đi Tiệc',
    desc: 'Nổi bật và sang trọng trong mọi bữa tiệc. Makeup được thiết kế phù hợp không gian và thời điểm.',
    features: ['Makeup ngày và tối', 'Phù hợp mọi loại tiệc', 'Sang trọng, thanh lịch', 'Bền màu nhiều giờ'],
    price: 'Từ 400.000đ',
    img: '/images/IMG_8399.JPG',
  },
  {
    icon: '📸',
    title: 'Makeup Chụp Ảnh',
    desc: 'Makeup được tối ưu cho ống kính — đẹp cả ngoài trời lẫn studio. Ánh sáng nào cũng đẹp.',
    features: ['Kỹ thuật makeup cho camera', 'Tối ưu ánh sáng tự nhiên & flash', 'Highlight & contour sắc nét', 'Bền màu suốt buổi chụp'],
    price: 'Từ 450.000đ',
    img: '/images/IMG_9013.JPG',
  },
  {
    icon: '🌸',
    title: 'Makeup Cá Nhân',
    desc: 'Giúp bạn tự tin mỗi ngày với look phù hợp. Từ makeup đi làm nhẹ nhàng đến makeup dạo phố, đi chơi.',
    features: ['Look phù hợp gương mặt', 'Tư vấn màu sắc riêng', 'Makeup tự nhiên nhẹ nhàng', 'Có thể dạy kỹ thuật cơ bản'],
    price: 'Từ 300.000đ',
    img: '/images/IMG_2922.JPG',
  },
  {
    icon: '🎭',
    title: 'Makeup Sân Khấu / Sự Kiện',
    desc: 'Makeup cho MC, người mẫu, diễn viên, sự kiện doanh nghiệp. Chuẩn ánh đèn, bền màu, ấn tượng.',
    features: ['Makeup chuẩn sân khấu', 'Bền màu dưới ánh đèn mạnh', 'Phong cách theo yêu cầu', 'Kinh nghiệm nhiều sự kiện lớn'],
    price: 'Từ 600.000đ',
    img: '/images/IMG_8561.JPG',
  },
];
---

<BaseLayout title="Dịch Vụ Makeup — AMI Makeup Academy" description="Dịch vụ makeup chuyên nghiệp: makeup cô dâu, kỷ yếu, đi tiệc, chụp ảnh, cá nhân tại Nam Định.">

  <!-- Header -->
  <div class="bg-ink py-20 text-center">
    <div class="max-w-2xl mx-auto px-6">
      <span class="section-label justify-center flex">Chuyên Nghiệp & Tin Cậy</span>
      <h1 class="font-serif text-5xl md:text-6xl font-semibold text-white">Dịch Vụ Makeup</h1>
      <p class="text-zinc-400 mt-4">Từ cô dâu ngày cưới đến kỷ yếu học sinh — AMI có mặt cho mọi khoảnh khắc đẹp.</p>
    </div>
  </div>

  <!-- Breadcrumb -->
  <div class="bg-cream border-b border-zinc-200">
    <div class="max-w-7xl mx-auto px-6 py-3 text-xs text-zinc-400">
      <a href="/" class="hover:text-gold transition-colors">Trang Chủ</a>
      <span class="mx-2">/</span>
      <span class="text-zinc-600">Dịch Vụ</span>
    </div>
  </div>

  <!-- Services -->
  <section class="py-20 bg-cream">
    <div class="max-w-7xl mx-auto px-6">
      <div class="space-y-8">
        {services.map((s, i) => (
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-0 bg-white border border-zinc-100 overflow-hidden card-hover ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
            <div class={`h-72 lg:h-auto overflow-hidden ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              <img src={s.img} alt={s.title} class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class={`p-10 flex flex-col justify-center ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <div class="text-3xl mb-4">{s.icon}</div>
              <h2 class="font-serif text-3xl font-semibold text-ink mb-3">{s.title}</h2>
              <p class="text-zinc-500 leading-relaxed mb-6">{s.desc}</p>
              <ul class="space-y-2 mb-7">
                {s.features.map(f => (
                  <li class="flex items-center gap-3 text-sm text-zinc-600">
                    <span class="text-gold text-lg shrink-0">✓</span>
                    {f}
                  </li>
                ))}
              </ul>
              <div class="flex items-center justify-between pt-5 border-t border-zinc-100">
                <div>
                  <div class="text-[9px] text-zinc-400 tracking-widest uppercase mb-1">Giá Tham Khảo</div>
                  <div class="text-gold font-bold text-xl">{s.price}</div>
                </div>
                <a href="/lien-he" class="btn-dark">Đặt Lịch</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gold text-center">
    <div class="max-w-2xl mx-auto px-6">
      <h2 class="font-serif text-3xl font-semibold text-white mb-4">Đặt Lịch Ngay Hôm Nay</h2>
      <p class="text-white/80 mb-8">Liên hệ để được tư vấn và đặt lịch phù hợp. Chúng tôi có mặt 7 ngày trong tuần.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="tel:0912345678" class="bg-white text-gold font-semibold text-sm tracking-widest uppercase px-8 py-4 hover:bg-cream transition-colors">Gọi Ngay</a>
        <a href="/lien-he" class="border-2 border-white text-white font-semibold text-sm tracking-widest uppercase px-8 py-4 hover:bg-white hover:text-gold transition-colors">Liên Hệ</a>
      </div>
    </div>
  </section>
</BaseLayout>
