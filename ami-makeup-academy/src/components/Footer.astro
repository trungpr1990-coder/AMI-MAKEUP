---
---

<footer class="bg-ink text-zinc-400">
  <div class="max-w-7xl mx-auto px-6 pt-16 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="font-serif text-white text-2xl tracking-widest mb-1">AMI</div>
        <div class="text-gold text-[9px] tracking-widest uppercase mb-5">Makeup Academy</div>
        <p class="text-sm text-zinc-500 leading-relaxed mb-6">
          Học viện đào tạo makeup chuyên nghiệp — nơi biến đam mê thành nghề nghiệp. Chứng chỉ được công nhận, giảng viên kinh nghiệm thực chiến.
        </p>
        <div class="flex gap-3">
          <a href="https://facebook.com/amimakeupacademy" target="_blank" class="w-8 h-8 border border-zinc-700 flex items-center justify-center hover:border-gold hover:text-gold transition-colors" aria-label="Facebook">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/amimakeupacademy" target="_blank" class="w-8 h-8 border border-zinc-700 flex items-center justify-center hover:border-gold hover:text-gold transition-colors" aria-label="Instagram">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://tiktok.com/@amimakeupacademy" target="_blank" class="w-8 h-8 border border-zinc-700 flex items-center justify-center hover:border-gold hover:text-gold transition-colors" aria-label="TikTok">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-white text-[10px] font-semibold tracking-widest uppercase mb-5 pb-3 border-b border-zinc-800">Khóa Học</h4>
        <ul class="space-y-2.5">
          {[
            ['Makeup Cơ Bản', '/khoa-hoc'],
            ['Makeup Nâng Cao', '/khoa-hoc'],
            ['Makeup Cô Dâu', '/khoa-hoc'],
            ['Makeup Cá Nhân', '/khoa-hoc'],
            ['Lịch Khai Giảng', '/khoa-hoc'],
          ].map(([label, href]) => (
            <li><a href={href} class="text-sm hover:text-gold transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="text-white text-[10px] font-semibold tracking-widest uppercase mb-5 pb-3 border-b border-zinc-800">Dịch Vụ</h4>
        <ul class="space-y-2.5">
          {[
            ['Makeup Cô Dâu', '/dich-vu'],
            ['Makeup Kỷ Yếu', '/dich-vu'],
            ['Makeup Đi Tiệc', '/dich-vu'],
            ['Makeup Chụp Ảnh', '/dich-vu'],
            ['Makeup Đi Chơi', '/dich-vu'],
          ].map(([label, href]) => (
            <li><a href={href} class="text-sm hover:text-gold transition-colors">{label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white text-[10px] font-semibold tracking-widest uppercase mb-5 pb-3 border-b border-zinc-800">Liên Hệ</h4>
        <ul class="space-y-3">
          <li class="flex gap-3 text-sm">
            <span class="text-gold mt-0.5 shrink-0">📍</span>
            <span>351 Lê Hồng Phong, TP. Nam Định</span>
          </li>
          <li class="flex gap-3 text-sm">
            <span class="text-gold mt-0.5 shrink-0">📞</span>
            <a href="tel:0912345678" class="hover:text-gold transition-colors">0912 345 678</a>
          </li>
          <li class="flex gap-3 text-sm">
            <span class="text-gold mt-0.5 shrink-0">✉</span>
            <a href="mailto:ami.makeup.academy@gmail.com" class="hover:text-gold transition-colors">ami.makeup.academy@gmail.com</a>
          </li>
          <li class="flex gap-3 text-sm">
            <span class="text-gold mt-0.5 shrink-0">🕐</span>
            <span>Thứ 2 – Chủ Nhật: 8:00 – 20:00</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-zinc-800 pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-xs text-zinc-600">
      <span>© 2026 AMI Makeup Academy. All rights reserved.</span>
      <div class="flex gap-5">
        <a href="/chinh-sach" class="hover:text-gold transition-colors">Chính Sách</a>
        <a href="/bao-mat" class="hover:text-gold transition-colors">Bảo Mật</a>
        <a href="/tuyen-dung" class="hover:text-gold transition-colors">Tuyển Dụng</a>
      </div>
    </div>
  </div>
</footer>
