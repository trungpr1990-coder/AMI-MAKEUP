---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'AMI Makeup Academy — Đào Tạo Makeup Chuyên Nghiệp',
  description = 'Học viện đào tạo makeup chuyên nghiệp hàng đầu. Makeup cô dâu, makeup cá nhân, makeup kỷ yếu, makeup đi tiệc tại TP. Nam Định.',
  image = '/images/og-image.jpg',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <title>{title}</title>
</head>
<body class="bg-white">
  <Header currentPath={currentPath} />
  <main>
    <slot />
  </main>
  <Footer />

  <!-- Zalo floating button -->
  <a
    href="https://zalo.me/0123456789"
    target="_blank"
    rel="noopener"
    class="fixed bottom-6 right-6 z-40 w-14 h-14 rounded-full shadow-lg hover:scale-110 transition-transform duration-200 flex items-center justify-center"
    aria-label="Chat Zalo"
  >
    <img src="/images/zalo-icon.svg" alt="Zalo" class="w-14 h-14" onerror="this.style.display='none';this.parentElement.style.background='#0068FF';this.parentElement.innerHTML='<span style=\'color:white;font-weight:700;font-size:14px\'>Zalo</span>';" />
  </a>
</body>
</html>
